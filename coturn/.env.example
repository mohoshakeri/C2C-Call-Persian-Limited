# Coturn STUN/TURN Installer Example
# Copy these values into the run command or export them before running install.sh.

# Optional but recommended for production and required for turns: TLS.
# Leave empty for IP-only turn: testing/production.
TURN_DOMAIN=turn.example.com

# Optional custom realm. If empty, TURN_DOMAIN is used; if TURN_DOMAIN is empty, public IP is used.
TURN_REALM=

# Required only when ENABLE_TLS=true and TURN_DOMAIN resolves to this server.
ADMIN_EMAIL=admin@example.com

# Set false if you do not have a domain yet. Plain turn: does not need TLS.
ENABLE_TLS=true

# If true, installation stops when DNS does not point to this server.
STRICT_DNS=false

# Keep true unless you manage the local firewall manually.
UFW_ENABLE=true

# Enable noisy per-session logs only while troubleshooting.
TURN_VERBOSE=false

# TURN credentials. Leave TURN_PASSWORD empty to auto-generate a strong hex password.
TURN_USER=mirotalk
TURN_PASSWORD=

# Ports. The default relay range is intentionally large for more concurrent calls.
TURN_PORT=3478
TURNS_PORT=5349
TURN_MIN_PORT=49160
TURN_MAX_PORT=65535

# Optional public IP override. Use only if automatic detection is wrong.
PUBLIC_IP_OVERRIDE=
