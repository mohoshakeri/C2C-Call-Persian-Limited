# Coturn STUN/TURN Installer Example
# Copy These Values Into The Run Command Or Export Them Before Running The Script

# Recommended For Production
TURN_DOMAIN=turn.example.com

# Required Only If ENABLE_TLS=true
ADMIN_EMAIL=admin@example.com

# Set False If You Do Not Have A Domain Yet
ENABLE_TLS=true

# If True, Installation Stops When DNS Does Not Point To This Server
STRICT_DNS=false

# Keep True Unless You Manage Firewall Manually
UFW_ENABLE=true

# TURN Credentials
# Leave TURN_PASSWORD Empty To Auto Generate A Strong Password
TURN_USER=mirotalk
TURN_PASSWORD=

# Ports
TURN_PORT=3478
TURNS_PORT=5349
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Optional Public IP Override
# Use Only If Automatic Detection Is Wrong
PUBLIC_IP_OVERRIDE=
